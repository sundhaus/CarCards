rules_version = '2';
service cloud.firestore {
match /databases/{database}/documents {
function isAuthenticated() {
return request.auth != null;
}
function isOwner(userId) {
return isAuthenticated() && request.auth.uid == userId;
}
function isAdmin() {
return isAuthenticated() && request.auth.uid == 'Ydnk69jI6kba4JiUYWEYBX8xDPU2';
}
match /users/{userId} {
  allow read: if isAuthenticated();
  allow create: if isOwner(userId);
  allow update: if isOwner(userId) || isAdmin();
  allow delete: if isOwner(userId);

  // User meta subcollection (dailyLogin, etc.)
  match /meta/{docId} {
    allow read, write: if isOwner(userId);
  }

  // Battle results subcollection (match history)
  match /battleResults/{resultId} {
    allow read: if isOwner(userId);
    allow create: if isOwner(userId);
    allow update: if false;
    allow delete: if isOwner(userId) || isAdmin();
  }
}

match /usernames/{username} {
  allow read: if true;
  allow write: if isAuthenticated();
}

match /cards/{cardId} {
  allow read: if isAuthenticated();
  allow create: if isAuthenticated();
  allow update: if isAuthenticated() && (
    resource.data.ownerId == request.auth.uid ||
    request.resource.data.diff(resource.data).affectedKeys().hasOnly(['h2hWins', 'h2hRaces']) ||
    request.resource.data.diff(resource.data).affectedKeys().hasOnly(['flatImageURL']) ||
    request.resource.data.diff(resource.data).affectedKeys().hasOnly(['flatImageURL', 'customFrame'])
  );
  allow delete: if isAuthenticated() && (
    resource.data.ownerId == request.auth.uid || isAdmin()
  );
}

match /listings/{listingId} {
  allow read: if isAuthenticated();
  allow create: if isAuthenticated();
  allow update: if isAuthenticated();
  allow delete: if isAuthenticated() && (
    resource.data.sellerId == request.auth.uid || isAdmin()
  );
}

match /follows/{followId} {
  allow read: if isAuthenticated();
  allow create: if isAuthenticated() && 
                  request.resource.data.followerId == request.auth.uid;
  allow delete: if isAuthenticated() && 
                  resource.data.followerId == request.auth.uid;
  allow update: if false;
}

match /friend_activities/{activityId} {
  allow read: if isAuthenticated();
  allow create: if isAuthenticated() && 
                  request.resource.data.userId == request.auth.uid;
  allow update: if isAuthenticated() && (
    resource.data.userId == request.auth.uid ||
    request.resource.data.diff(resource.data).affectedKeys().hasOnly(['heatedBy', 'heatCount']) ||
    request.resource.data.diff(resource.data).affectedKeys().hasOnly(['commentCount'])
  );
  allow delete: if isAuthenticated() && (
    resource.data.userId == request.auth.uid || isAdmin()
  );
  
  // Comments subcollection
  match /comments/{commentId} {
    allow read: if isAuthenticated();
    allow create: if isAuthenticated()
      && request.resource.data.userId == request.auth.uid
      && request.resource.data.text is string
      && request.resource.data.text.size() > 0
      && request.resource.data.text.size() <= 500;
    allow delete: if isAuthenticated() && (
      resource.data.userId == request.auth.uid || isAdmin()
    );
    allow update: if false;
  }
}

match /vehicleSpecs/{docId} {
  allow read: if true;
  allow create: if isAuthenticated();
  allow update: if isAuthenticated();
  allow delete: if false;
}

match /featured_cards/{cardId} {
  allow read: if true;
  allow create: if isAuthenticated();
  allow update: if isAuthenticated();
  allow delete: if false;
}

// ─── Battle Arena: Battles ───────────────────────────────
match /battles/{battleId} {
  allow read: if isAuthenticated();
  allow create: if isAuthenticated();
  allow update: if isAuthenticated();
  allow delete: if isAuthenticated() && isAdmin();
}

// ─── Battle Arena: Battle Queue ──────────────────────────
match /battleQueue/{queueId} {
  allow read: if isAuthenticated();
  allow create: if isAuthenticated();
  allow update: if isAuthenticated();
  allow delete: if isAuthenticated();
}

// ─── Head to Head: Races ─────────────────────────────────
match /races/{raceId} {
  allow read: if isAuthenticated();
  allow create: if isAuthenticated()
                && request.resource.data.challengerId == request.auth.uid;
  allow update: if isAuthenticated();
  allow delete: if isAuthenticated() && (
    resource.data.challengerId == request.auth.uid || isAdmin()
  );
}

// ─── Head to Head: Race Votes ────────────────────────────
match /raceVotes/{voteId} {
  allow read: if isAuthenticated();
  allow create: if isAuthenticated()
                && request.resource.data.voterId == request.auth.uid;
  allow update: if false;
  allow delete: if isAdmin();
}

// ─── Head to Head: Vote Streaks ──────────────────────────
match /voteStreaks/{userId} {
  allow read: if isAuthenticated();
  allow create: if isAuthenticated();
  allow update: if isAuthenticated();
}

// ─── Head to Head: Card Cooldowns ────────────────────────
match /cardCooldowns/{cardId} {
  allow read: if isAuthenticated();
  allow write: if isAuthenticated();
}

// ─── Head to Head: Duo Invites ───────────────────────────
match /duoInvites/{inviteId} {
  allow read: if isAuthenticated();
  allow create: if isAuthenticated()
                && request.resource.data.inviterId == request.auth.uid;
  allow update: if isAuthenticated();
  allow delete: if isAuthenticated();
}

match /featured_cards/{docId} {
  allow read: if true;
  allow write, delete: if request.auth.uid in ['Ydnk69jI6kba4JiUYWEYBX8xDPU2'];
}

match /counters/{counterId} {
  allow read: if isAuthenticated();
  allow write: if isAuthenticated();
}
}
}
